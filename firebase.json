{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "dubis-app-v3.html",
      "dubis-private-app-v2.html"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/dubis-app-v4.html",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
